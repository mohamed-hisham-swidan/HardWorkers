# ════════════════════════════════════════════════════
# HardWorkres — Environment Configuration
# ════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
# NEVER commit the `.env` file to version control.
# ════════════════════════════════════════════════════

# ── Ollama ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Database ───────────────────────────────────────
DB_PATH=./data/hardworkers.db

# ── Vector Store ───────────────────────────────────
VECTOR_INDEX_DIR=./data/faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# ── Logging ────────────────────────────────────────
LOG_DIR=./logs

# ── UI ─────────────────────────────────────────────
UI_WIDTH=1280
UI_HEIGHT=900

# ── Token limits ───────────────────────────────────
MAX_CONTEXT_TOKENS=3072
MAX_ACTIVE_TOKENS=2500
HISTORY_WINDOW_TOKENS=1500

# ── External API providers ─────────────────────────
# Set these only if you use external model providers.
# Keys are stored in the local SQLite database at
# runtime — keep your .env file secure.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
